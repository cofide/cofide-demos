# Cofide Connect API settings.
CONNECT_URL="<connect host:port>"
CONNECT_TRUST_DOMAIN="<connect trust domain>"
CONNECT_BUNDLE_HOST="<connect bundle host>"
AUTHORIZATION_DOMAIN="<authz domain>"
AUTHORIZATION_CLIENT_ID="<authz client ID>"

# Workload cluster settings.
WORKLOAD_K8S_CLUSTER_NAME=cofide-capital
WORKLOAD_K8S_CLUSTER_CONTEXT=kind-cofide-capital
WORKLOAD_TRUST_ZONE=cofide-capital
WORKLOAD_TRUST_DOMAIN=cofide-capital.test

# Namespace containing the demo workloads. The Connect attestation policy is
# namespace-scoped to match the connect-reference workloads architecture.
NAMESPACE=production

# Set to true to create a fresh Kind cluster before running cofidectl.
# Leave false when you already have a Kind cluster running v1.
CREATE_KIND_CLUSTER=false

# If CREATE_KIND_CLUSTER=true, mount Docker credentials into the Kind node so
# private registry pulls work. Local Kind image loading does not need this.
PATH_TO_HOST_DOCKER_CREDENTIALS="${HOME}/.docker/config.json"
